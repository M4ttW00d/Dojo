DEBUG=True
SECRET_KEY=your-secret-key-here
DB_NAME=dojo
DB_USER=dojo_user
DB_PASSWORD=your-password-here
DB_ROOT_PASSWORD=your-root-password-here

# Email — leave blank to use console backend (prints to docker logs)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=Backwell Judo Club <no-reply@example.com>

# Stripe — get these from your Stripe dashboard (use test keys for dev)
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret — from `stripe listen --forward-to localhost:8000/stripe/webhook/`
STRIPE_WEBHOOK_SECRET=whsec_...

# Public URL — used to build links in emails and Stripe redirects
SITE_URL=https://yourdomain.com